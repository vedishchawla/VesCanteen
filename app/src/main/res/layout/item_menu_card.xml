<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Food Image -->
            <ImageView
                android:id="@+id/ivFoodImage"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:scaleType="centerCrop"
                android:contentDescription="Food Image" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp">

                <!-- Food Name -->
                <TextView
                    android:id="@+id/tvFoodName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Food Name"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <!-- Price Row -->
                <TextView
                    android:id="@+id/tvPrice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="₹0"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- ADD button (shown when qty = 0) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAdd"
            android:layout_width="70dp"
            android:layout_height="32dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="96dp"
            android:layout_marginEnd="8dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="ADD"
            android:textSize="12sp"
            android:textStyle="bold"
            android:padding="0dp"
            app:cornerRadius="8dp"
            android:backgroundTint="@color/accent"
            style="@style/Widget.MaterialComponents.Button" />

        <!-- Quantity stepper (shown when qty > 0) -->
        <LinearLayout
            android:id="@+id/quantityStepper"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="96dp"
            android:layout_marginEnd="8dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/stepper_bg"
            android:visibility="gone"
            android:elevation="4dp">

            <TextView
                android:id="@+id/btnStepperMinus"
                android:layout_width="28dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="−"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/tvStepperCount"
                android:layout_width="24dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="1"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/primary" />

            <TextView
                android:id="@+id/btnStepperPlus"
                android:layout_width="28dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="+"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

    </FrameLayout>
</com.google.android.material.card.MaterialCardView>
